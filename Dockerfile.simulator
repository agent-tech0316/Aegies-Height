FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    MUJOCO_GL=egl

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
      libegl1 \
      libgl1 \
      libglib2.0-0 \
      libglvnd0 \
      libglx0 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY pyproject.toml README.md LICENSE ./
COPY requirements-sim-server.txt ./
COPY agentech ./agentech

RUN pip install --no-cache-dir -r requirements-sim-server.txt \
    && pip install --no-cache-dir -e .

EXPOSE 8000

CMD ["sh", "-c", "uvicorn agentech.sim_server:app --host 0.0.0.0 --port ${PORT:-8000}"]
